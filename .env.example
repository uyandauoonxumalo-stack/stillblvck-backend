# ═══════════════════════════════════════════════════════
# StillBlvck Elite Bot v3 — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env — NEVER commit .env to GitHub

# ── SERVER ──────────────────────────────────────────────
PORT=10000
NODE_ENV=production
FRONTEND_URL=https://stillblvck-elite-bot.netlify.app
LOG_LEVEL=INFO

# ── DATABASE ─────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.XXXXX.mongodb.net/stillblvck?retryWrites=true&w=majority

# ── MARKET DATA (FREE APIs) ───────────────────────────────
# Finnhub: https://finnhub.io → Dashboard → API Key
FINNHUB_API_KEY=your_finnhub_key_here

# TwelveData: https://twelvedata.com → Account → API Keys
TWELVEDATA_API_KEY=your_twelvedata_key_here

# ── WHATSAPP ALERTS (FREE via CallMeBot) ─────────────────
# 1. Save +34 644 31 32 26 in phone
# 2. Send: "I allow callmebot to send me messages"
# 3. You'll receive your key via WhatsApp
USER_WHATSAPP_NUMBER=27674752818
CALLMEBOT_KEY=your_callmebot_key_here

# ── TELEGRAM ALERTS (OPTIONAL) ────────────────────────────
# BotFather: @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Your chat ID: message @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── SIGNAL CONFIG ─────────────────────────────────────────
MIN_CONFIDENCE=75
SIGNAL_COOLDOWN_MINUTES=5

# ── RISK MANAGEMENT ───────────────────────────────────────
MAX_OPEN_TRADES=3
MAX_TRADES_PER_DAY=10
DAILY_DRAWDOWN_LIMIT=5
RISK_PER_TRADE=1

# ── EXECUTION MODE ────────────────────────────────────────
# SIMULATION = safe mode, no real trades (recommended)
# MANUAL     = queue signals for manual confirmation
# AUTO       = disabled for safety
EXECUTION_MODE=SIMULATION

# ── SECURITY (OPTIONAL) ───────────────────────────────────
INTERNAL_API_KEY=change_this_to_a_long_random_string
