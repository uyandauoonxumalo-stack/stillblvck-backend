# ═══════════════════════════════════════════════════
# StillBlvck Elite Bot v3 — Environment Variables
# Copy to .env — NEVER commit .env to GitHub
# ═══════════════════════════════════════════════════

# Server
PORT=10000
NODE_ENV=production
FRONTEND_URL=https://stillblvck-elite-bot.netlify.app
LOG_LEVEL=INFO

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/stillblvck?retryWrites=true&w=majority

# Market Data APIs (FREE)
FINNHUB_API_KEY=your_finnhub_key
TWELVEDATA_API_KEY=your_twelvedata_key

# WhatsApp (CallMeBot — FREE)
USER_WHATSAPP_NUMBER=27674752818
CALLMEBOT_KEY=your_callmebot_key

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Twilio WhatsApp (optional alternative to CallMeBot)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Security
INTERNAL_API_KEY=change_this_to_long_random_string

# Signal Config
MIN_CONFIDENCE=75
SIGNAL_COOLDOWN_MINUTES=5
MAX_OPEN_TRADES=3
MAX_TRADES_PER_DAY=10
DAILY_DRAWDOWN_LIMIT=5
RISK_PER_TRADE=1

# Execution Mode: SIMULATION | MANUAL | AUTO
EXECUTION_MODE=SIMULATION
